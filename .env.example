# ============================================
# Team SOP Reminder Creator - Environment Config
# ============================================
# Copy this file to .env and fill in your values.

# --- Database (MySQL) ---
DB_HOST=localhost
DB_NAME=sop_reminders
DB_USER=
DB_PASS=

# --- Hospitable API ---
HOSPITABLE_API_TOKEN=

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL_ID=

# Slack user ID to ping on failure alerts
SLACK_FAILURE_USER_ID=U03S5GQ2CDP

# --- Web UI Auth ---
AUTH_USER=admin
AUTH_PASS=changeme

# --- Shift Schedule (BDT / UTC+6) ---
SHIFT_START_HOUR=6
SHIFT_DURATION_HOURS=4

# --- Reminder Timing ---
# Default hours before check-in to target the reminder
REMINDER_HOURS_BEFORE=12

# --- API Mode ---
# Set to "mock" to use mock_api.php for testing, "live" for real Hospitable API
API_MODE=live
